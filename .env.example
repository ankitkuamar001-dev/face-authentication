# ─── Application ─────────────────────────────────────────────────
APP_NAME="Face Authentication API"
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── JWT Settings ─────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_VERY_LONG_SECURE_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=faceauth
POSTGRES_PASSWORD=faceauth_dev_password
POSTGRES_DB=faceauth_db
DATABASE_URL=postgresql+asyncpg://faceauth:faceauth_dev_password@db:5432/faceauth_db

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MinIO / S3 ───────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=face-thumbnails
MINIO_SECURE=false

# ─── ML Pipeline ─────────────────────────────────────────────────
FACE_MODEL=ArcFace
FACE_DETECTOR_BACKEND=retinaface
# Cosine distance threshold (ArcFace: lower = stricter). Default 0.68 → similarity ~0.32
SIMILARITY_THRESHOLD=0.32

# ─── Security & Rate Limiting ─────────────────────────────────────
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=1800
RATE_LIMIT_PER_MINUTE=30

# ─── OTP Email Fallback (SMTP) ────────────────────────────────────
# Set SMTP_CONSOLE_OUTPUT=true for development (prints OTP to console instead of sending)
SMTP_CONSOLE_OUTPUT=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@faceauth.app
OTP_EXPIRE_MINUTES=5
